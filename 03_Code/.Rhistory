ggplot(km_cens, aes(x = times, y = surv)) +
geom_step(linewidth = 1, colour = "blue") +
labs(title = "Kaplan-Meier Survival Curve",
x = "Time",
y = "Survival probability") +
theme_minimal() + ylim(c(0,1))
(q <- quantile(datnocens$times, c(0.25,0.5,0.75)))
