pvalsAD[i] <- try(all3$pval[3])
SEC <- try(KScens(times, cens, distr = h0, boot = FALSE))
pvalsKS_noboot[i] <- SEC$Test[[2]]
km <- survfit(Surv(times, cens) ~ 1)
km_min[i] <- tail(km$surv, 1)
t_max[i] <- tail(km$time, 1)
SEC_min[i] <- 1 - switch(h0,
