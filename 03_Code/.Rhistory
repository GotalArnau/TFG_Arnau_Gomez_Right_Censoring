lognormal = plnorm(q = t_max[i], meanlog = SEC$Estimates[[1]], sdlog = SEC$Estimates[[2]]),
logistic = plogis(q = t_max[i], location = SEC$Estimates[[1]], scale = SEC$Estimates[[2]]))
}
results <- data.frame(
pvalsCvM = pvalsCvM,
pvalsKS =  pvalsKS,
