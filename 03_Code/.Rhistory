Cal_skewness <- function(data, only.obs = FALSE, bowly = TRUE){
bwly <- as.numeric()
if(only.obs){data <- subset(data, cens == 1)}
times <- data$times
cens <- data$cens
if(bowly){quant <- c(0.25, 0.5, 0.75)}else{quant <- c(0.1, 0.5,0.9)}
q <- quantile(times, probs = quant)
bwly <- as.numeric((q[1] - 2 * q[2] + q[3]) / (q[3] - q[1]))
return(bwly)
}
