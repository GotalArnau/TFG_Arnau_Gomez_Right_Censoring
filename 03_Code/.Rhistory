#Bowly's Coefficient:
bowley <- function(x, alpha = 0.25, obs = FALSE){
if(obs == TRUE){ x <- subset(x, cens == 1)}
q <- quantile(x$times, c(alpha, 0.5, 1 - alpha))
bs <- as.numeric((q[1] - 2 * q[2] + q[3]) / (q[3] - q[1]))
return (bs)
}
#Kelly's Coefficient:
kelly <- function(x, alpha = 0.1, obs = FALSE){
if(obs == TRUE){ x <- subset(x, cens == 1)}
p <- quantile(x$times, c(alpha,0.5, 1 - alpha))
ks <- as.numeric((p[3] + p[1] - 2*p[2]) / (p[3] - p[1]))
return(ks)
}
