legend.text = element_text(size = 20),
plot.subtitle = element_text(size = 20, face = "italic", hjust = 0.5),
axis.title = element_text(size = 20, face = "bold"),
axis.text = element_text(size = 15, angle = 35),
strip.text = element_text(size = 15))))
ggsave(filename = "04_Output/Figures/Diff_Power_each_test_Lognormal_1.png", plot = p_final, width = 2500*3, height = 1800, units = "px")
